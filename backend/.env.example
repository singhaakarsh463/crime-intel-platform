# ─── Backend ────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

# Database connection string
# SQLite (dev):    sqlite:///./crime_intel.db
# PostgreSQL:      postgresql+psycopg2://user:password@db:5432/crime_intel
DATABASE_URL=sqlite:///./crime_intel.db

# Anthropic API key — required for AI-generated answers in the chat assistant
# Without this, the assistant still returns retrieved case snippets
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Dev:  http://localhost:5173
# Prod: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# ─── Rate limiting ──────────────────────────────────────────────────────────
# slowapi limit strings — see https://limits.readthedocs.io/
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_CHAT=30/minute
